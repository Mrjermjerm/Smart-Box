user_file = "users.txt"
nickname_file = "nicknames.txt"
log_file = "activity.log"


# -------------------------
# NICKNAME STORAGE
# -------------------------
def load_nicknames():
    nicknames = {}
    if not os.path.exists(nickname_file):
        return nicknames
    with open(nickname_file, "r") as f:
        for line in f:
            if ":" in line:
                mac, nickname = line.strip().split(":", 1)
                nicknames[mac] = nickname
    return nicknames

def save_nickname(mac, nickname):
    nicknames = load_nicknames()
    nicknames[mac] = nickname
    with open(nickname_file, "w") as f:
        for m, n in nicknames.items():
            f.write(f"{m}:{n}\n")

# -------------------------
# ACTIVITY LOGGING
# -------------------------
def write_log(action, details=""):
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    if has_request_context():
        user = session.get("user", "SYSTEM")
        ip_address = request.remote_addr
    else:
        user = "SYSTEM"
        ip_address = "LOCAL"

    log_entry = f"{timestamp} | User: {user} | IP: {ip_address} | Action: {action} | Details: {details}\n"

    with open(log_file, "a") as f:
        f.write(log_entry)

def read_logs(action=None, user=None, ip=None):
    if not os.path.exists(log_file):
        return []

    filtered_logs = []

    with open(log_file, "r") as f:
        for line in f:
            if action and f"Action: {action}" not in line:
                continue
            if user and f"User: {user}" not in line:
                continue
            if ip and f"IP: {ip}" not in line:
                continue
            filtered_logs.append(line)

    return filtered_logs[::-1]  # newest first

def get_log_filter_options():
    actions = set()
    users = set()
    ips = set()

    if not os.path.exists(log_file):
        return actions, users, ips

    with open(log_file, "r") as f:
        for line in f:
            if "Action:" in line:
                actions.add(line.split("Action:")[1].split("|")[0].strip())
            if "User:" in line:
                users.add(line.split("User:")[1].split("|")[0].strip())
            if "IP:" in line:
                ips.add(line.split("IP:")[1].split("|")[0].strip())

    return sorted(actions), sorted(users), sorted(ips)

# -------------------------
# ARP NETWORK SCAN
# -------------------------
def arp_scan():
    result = subprocess.run(["arp", "-a"], capture_output=True, text=True)
    devices = []
    for line in result.stdout.splitlines():
        match = re.search(r"(\d+\.\d+\.\d+\.\d+)\s+([-\w]+)\s+dynamic", line)
        if match:
            devices.append({"ip": match.group(1), "mac": match.group(2)})
    return devices

# -------------------------
# TASMOTA CONTROL
# -------------------------
def tasmota_power(ip, action):
    """Send Power ON/OFF command to Tasmota device"""
    try:
        r = requests.get(f"http://{ip}/cm?cmnd=Power%20{action}", timeout=2)
        if r.status_code == 200:
            return r.json()
    except Exception as e:
        print(f"Tasmota request failed for {ip}: {e}")
    return None

# -------------------------
# PASSWORD HASHING
# -------------------------
def hash_password(password):
    return hashlib.sha256(password.encode()).hexdigest()

def user_exists(username):
    if not os.path.exists(user_file):
        return False
    with open(user_file, "r") as f:
        return any(line.startswith(f"{username}:") for line in f)

def verify_user(username, password):
    if not os.path.exists(user_file):
        return False
    hashed = hash_password(password)
    with open(user_file, "r") as f:
        for line in f:
            if line.strip() == f"{username}:{hashed}":
                return True
    return False

