@app.route("/logs/export")
def export_logs():
    if "user" not in session:
        return redirect(url_for("login"))

    action = request.args.get("action")
    user_filter = request.args.get("user")
    ip = request.args.get("ip")

    logs = read_logs(
        action=action if action else None,
        user=user_filter if user_filter else None,
        ip=ip if ip else None
    )

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = f"activity_logs_{timestamp}.log"

    # Build file in memory
    buffer = BytesIO()
    for log in logs[::-1]:  # oldest → newest
        buffer.write(log.encode("utf-8"))

    buffer.seek(0)

    write_log(
        "LOG_EXPORT",
        f"Exported logs | Action={action or 'ALL'} | User={user_filter or 'ALL'} | IP={ip or 'ALL'}"
    )

    return send_file(
        buffer,
        as_attachment=True,
        download_name=filename,
        mimetype="text/plain"
    )

