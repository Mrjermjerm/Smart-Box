@app.route("/scan")
def scan():
    if "user" not in session:
        return redirect(url_for("login"))

    devices = arp_scan()
    nicknames = load_nicknames()

    # Detect Tasmota devices
    for device in devices:
        ip = device["ip"]
        try:
            resp = requests.get(f"http://{ip}/cm?cmnd=Power", timeout=2)
            device["tasmota"] = resp.status_code == 200 and "POWER" in resp.text
        except:
            device["tasmota"] = False

    return render_template_string("""
